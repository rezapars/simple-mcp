{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.27/MicrosoftTeams.schema.json",
  "manifestVersion": "1.27",
  "version": "1.0.0",
  "id": "11111111-1111-1111-1111-111111111111",
  "developer": {
    "name": "Contoso",
    "websiteUrl": "https://example.com",
    "privacyUrl": "https://example.com/privacy",
    "termsOfUseUrl": "https://example.com/terms"
  },
  "name": {
    "short": "Client MCP",
    "full": "Client Onboarding MCP for Teams and Copilot"
  },
  "description": {
    "short": "Client onboarding MCP tools.",
    "full": "A sample Microsoft Teams and Microsoft 365 Copilot app package that connects to a Python MCP server for client onboarding status and basic client information."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#2563EB",
  "bots": [
    {
      "botId": "22222222-2222-2222-2222-222222222222",
      "scopes": ["personal", "team", "groupChat"],
      "supportsFiles": false,
      "isNotificationOnly": false,
      "commandLists": [
        {
          "scopes": ["personal", "team", "groupChat"],
          "commands": [
            {
              "title": "onboarding status",
              "description": "Get onboarding status for a client."
            },
            {
              "title": "client name",
              "description": "Get a client's name or family name."
            }
          ]
        }
      ]
    }
  ],
  "validDomains": ["example.ngrok-free.app"],
  "webApplicationInfo": {
    "id": "33333333-3333-3333-3333-333333333333",
    "resource": "api://example.ngrok-free.app/33333333-3333-3333-3333-333333333333"
  },
  "copilotAgents": {
    "declarativeAgents": [
      {
        "id": "clientOnboardingAgent",
        "file": "declarativeAgent.json"
      }
    ]
  }
}
