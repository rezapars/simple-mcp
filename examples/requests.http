### Health
GET http://localhost:8000/health

### Tool metadata
GET http://localhost:8000/api/v1/tools

### REST authentication
POST http://localhost:8000/api/v1/authenticate
Content-Type: application/json
x-mcp-session-id: demo-session

{
  "client_id": "123",
  "otp": "9632"
}

### REST authenticated onboarding status
GET http://localhost:8000/api/v1/client/onboarding-status
x-mcp-session-id: demo-session

### REST authenticated basic info
GET http://localhost:8000/api/v1/client/basic-info/name
x-mcp-session-id: demo-session

### REST authenticated facility limit
GET http://localhost:8000/api/v1/client/facility
x-mcp-session-id: demo-session

### REST authenticated outreach summary
GET http://localhost:8000/api/v1/client/outreach-summary
x-mcp-session-id: demo-session

### REST tool 1
GET http://localhost:8000/api/v1/clients/123/onboarding-status

### REST tool 2 - name
GET http://localhost:8000/api/v1/clients/123/basic-info/name

### REST tool 2 - family
GET http://localhost:8000/api/v1/clients/123/basic-info/family

### REST tool 3 - facility limit
GET http://localhost:8000/api/v1/clients/123/facility

### REST tool 4 - outreach summary
GET http://localhost:8000/api/v1/clients/123/outreach-summary

### MCP tools/list
POST http://localhost:8000/mcp
Content-Type: application/json
x-mcp-session-id: demo-session

{
  "jsonrpc": "2.0",
  "id": 1,
  "method": "tools/list"
}

### MCP tools/call before authentication
POST http://localhost:8000/mcp
Content-Type: application/json
x-mcp-session-id: new-session

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {
    "name": "get_client_onboarding_status",
    "arguments": {}
  }
}

### MCP authenticate_client
POST http://localhost:8000/mcp
Content-Type: application/json
x-mcp-session-id: demo-session

{
  "jsonrpc": "2.0",
  "id": 2,
  "method": "tools/call",
  "params": {
    "name": "authenticate_client",
    "arguments": {
      "client_id": "123",
      "otp": "9632"
    }
  }
}

### MCP tools/call - basic info after authentication
POST http://localhost:8000/mcp
Content-Type: application/json
x-mcp-session-id: demo-session

{
  "jsonrpc": "2.0",
  "id": 3,
  "method": "tools/call",
  "params": {
    "name": "get_client_basic_info",
    "arguments": {
      "field": "name"
    }
  }
}

### MCP tools/call - facility limit
POST http://localhost:8000/mcp
Content-Type: application/json
x-mcp-session-id: demo-session

{
  "jsonrpc": "2.0",
  "id": 4,
  "method": "tools/call",
  "params": {
    "name": "get_client_facility_limit",
    "arguments": {}
  }
}

### MCP tools/call - outreach summary
POST http://localhost:8000/mcp
Content-Type: application/json
x-mcp-session-id: demo-session

{
  "jsonrpc": "2.0",
  "id": 5,
  "method": "tools/call",
  "params": {
    "name": "summarize_client_outreach",
    "arguments": {}
  }
}
