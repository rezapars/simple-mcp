{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "MCP Server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["mcp_server.app:app", "--host", "0.0.0.0", "--port", "8000", "--reload"],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Mock Backend",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["mock_backend.app:app", "--host", "0.0.0.0", "--port", "8001", "--reload"],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    },
    {
      "name": "Pytest",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q"],
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}
