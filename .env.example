# MCP server
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_BACKEND_BASE_URL=http://localhost:8001
MCP_REQUEST_TIMEOUT_SECONDS=10
MCP_LOG_LEVEL=INFO

# Authentication placeholder.
# Keep disabled for local development. Enable in hosted environments and send x-api-key.
MCP_AUTH_REQUIRED=false
MCP_API_KEY_HEADER=x-api-key
MCP_API_KEY=local-dev-key

# Mock backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8001
BACKEND_LOG_LEVEL=INFO
